# --- Convex ---
# Set automatically by `npx convex dev`. Identifies the dev deployment.
CONVEX_DEPLOYMENT=dev:your-deployment-name
# Public Convex endpoint the browser client connects to.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-name.convex.cloud
# Convex HTTP actions endpoint (webhooks, file serving).
CONVEX_SITE_URL=https://your-deployment-name.convex.site

# --- Clerk (auth) ---
# From the Clerk Dashboard → API keys. The publishable key is safe to expose.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# Server-only secret. Never commit the real value.
CLERK_SECRET_KEY=sk_test_xxx
