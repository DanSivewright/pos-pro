# Written automatically by `npx convex dev` — do not edit by hand.
CONVEX_DEPLOYMENT=dev:your-deployment-name
CONVEX_URL=https://your-deployment-name.convex.cloud
CONVEX_SITE_URL=https://your-deployment-name.convex.site

# NOTE: the following are NOT read from this file. They live ON the Convex
# deployment and are set with `npx convex env set <NAME> <value>`:
#
#   CLERK_JWT_ISSUER_DOMAIN   Clerk Frontend API / issuer domain backing the
#                             "convex" JWT template, e.g.
#                             https://your-instance.clerk.accounts.dev
#   RESEND_API_KEY            Resend key for the daily exception-alert digest.
#   CLERK_SECRET_KEY          Clerk backend key; the digest reads org members
#                             and super-users to resolve recipients.
#   DIGEST_FROM_EMAIL         Verified Resend sender, e.g. alerts@yourdomain.com
#   DIGEST_HOUR_UTC           Cron hour (UTC) for the digest. Default 4 (=06:00
#                             SAST).
#   DIGEST_MINUTE_UTC         Cron minute (UTC) for the digest. Default 0.
